{
  "name": "@crucible/plugin-example-template",
  "version": "1.0.0",
  "description": "Example template plugin for Crucible",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest"
  },
  "keywords": [
    "crucible",
    "plugin",
    "template"
  ],
  "author": "Crucible Team",
  "license": "MIT",
  "peerDependencies": {
    "@crucible/core": ">=1.0.0"
  },
  "devDependencies": {
    "@crucible/core": "^1.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "crucible": {
    "type": "template",
    "hooks": [
      "template:register",
      "template:before-render"
    ],
    "permissions": [
      "read:templates",
      "write:files"
    ]
  }
}

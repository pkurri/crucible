# ═══════════════════════════════════════════════════════════════
# ⚡ NEON ARCADE — Game Studio Agent Config
# ═══════════════════════════════════════════════════════════════

# ── FREE TIER: Groq (recommended) ───────────────────────────────
# Get a free API key at https://console.groq.com
# Models: llama-3.3-70b-versatile, llama-3.1-8b-instant, mixtral-8x7b-32768
LLM_PROVIDER=groq
LLM_MODEL=groq/llama-3.3-70b-versatile
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx

# ── FREE TIER: Ollama (fully local, zero cost) ──────────────────
# Install: https://ollama.com  →  ollama pull llama3.2
# LLM_PROVIDER=ollama
# LLM_MODEL=ollama/llama3.2
# OLLAMA_BASE_URL=http://localhost:11434

# ── OpenAI (paid) ───────────────────────────────────────────────
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx

# ── Workspace ───────────────────────────────────────────────────
WORKSPACE_DIR=./workspace

# ── Human-in-the-Loop Checkpoints ───────────────────────────────
# When enabled the pipeline pauses after PULSE (market analysis)
# and GATEWAY (store compliance) for manual approval.
CHECKPOINT_ENABLED=true

# ── Message Queue (optional, for distributed mode) ──────────────
# REDIS_URL=redis://localhost:6379

# ── Vercel / Next.js ────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# A random secret protecting the internal worker endpoint
# Generate with: openssl rand -hex 32
PIPELINE_WORKER_SECRET=replace_with_random_secret

# ── Supabase (Crucible Hub) ──────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://zwwlcqttdmbmyfvdogwr.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ─────────────────────────────────────────────────────────────────────────────
# Crucible AI Forge — Environment Variables
# Copy this to .env.local and fill in your keys.
#
# Every provider below has a FREE tier. Sign up and get API keys:
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
# https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── AI Providers (Free Tiers) — Add as many as you can for resilience ─────────

# 1. Google Gemini — 1,500 req/day FREE
#    https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# 2. Cerebras — FREE tier, ultra-fast Llama inference
#    https://cloud.cerebras.ai
CEREBRAS_API_KEY=

# 3. Groq — ~14,400 req/day FREE, extremely fast
#    https://console.groq.com/keys
GROQ_API_KEY=

# 4. SambaNova — FREE tier, fast Llama-3.3 70B & DeepSeek
#    https://cloud.sambanova.ai
SAMBANOVA_API_KEY=

# 5. Together AI — FREE $5 credit + free model tier
#    https://api.together.ai/settings/api-keys
TOGETHER_API_KEY=

# 6. Mistral AI — FREE tier (La Plateforme), 1 req/sec
#    https://console.mistral.ai/api-keys
MISTRAL_API_KEY=

# 7. OpenRouter — FREE :free model pool (DeepSeek, Kimi, Phi-3, Gemma, etc.)
#    https://openrouter.ai/keys
OPENROUTER_API_KEY=

# 8. Anthropic — Paid but low cost (Claude 3.5 Haiku, last resort)
#    https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# 9. Cloudflare Workers AI — 10,000 req/day FREE
#    https://dash.cloudflare.com/ (AI -> Workers AI)
CLOUDFLARE_API_KEY=
CLOUDFLARE_ACCOUNT_ID=

# 10. DeepSeek Direct — High priority reasoning
#     https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# 11. Fireworks AI — $1 free credit / low cost
#     https://fireworks.ai/api-keys
FIREWORKS_API_KEY=
